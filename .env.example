# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# Database path (default: ./data/bot.db)
DATABASE_PATH="./data/bot.db"

# 32-byte hex key for wallet encryption
# IMPORTANT: Generate a secure 64-character hex string (e.g., using `require('crypto').randomBytes(32).toString('hex')`)
# Do NOT lose this key, or you will lose access to all wallets in the database!
ENCRYPTION_KEY="ENTER_64_CHARACTER_HEX_STRING_HERE"

# ---------------------------------------------------------
# RPC Configuration (Round-Robin Pool)
# Add as many RPC endpoints as you want (up to 100).
# The bot will automatically rotate through them to avoid rate limits.
# ---------------------------------------------------------
RPC_KEY_1="https://api.mainnet-beta.solana.com"
# RPC_KEY_2="https://your-helius-or-alchemy-url.com"
# RPC_KEY_3=""
# ... 
# RPC_KEY_100=""

# ---------------------------------------------------------
# Jupiter Ultra API Configuration
# Add your Jupiter Ultra API keys here.
# The bot uses these for MEV protection, gasless swaps, and priority fees.
# ---------------------------------------------------------
# JUPITER_ULTRA_KEY_1="YOUR_JUPITER_KEY_1"
# JUPITER_ULTRA_KEY_2="YOUR_JUPITER_KEY_2"
# ...
# JUPITER_ULTRA_KEY_10="YOUR_JUPITER_KEY_10"
